# Human-readable name shown in the catalog JSON and homepage
SOURCE_NAME=xyNasTools Plugin Registry

# Public URL where this registry is reachable (used to build download URLs in the catalog)
# Set this to the URL your xyNasTools Core instance uses to reach this server.
SOURCE_URL=http://localhost:12139

# Simple password key required to access catalog.json and download plugins.
# Leave empty to allow unauthenticated access (internal-network-only setups).
# Anyone who knows this key can browse and download all plugins.
AUTH_TOKEN=

# Host port to expose (maps to container port 12139)
PORT=12139

# CORS origin for browser-side requests. Leave empty if Core calls this server-side only.
# Example: https://nas.example.com
ALLOWED_ORIGIN=

# How long (seconds) the plugin catalog is cached in memory before rebuilding from disk.
CATALOG_TTL=60

# Number of gunicorn worker processes. Increase for higher concurrency.
GUNICORN_WORKERS=2

# Path inside the container where .xte plugin files are stored.
# Mount a host directory here to persist plugins across rebuilds.
# PLUGINS_DIR=/app/plugins

# Path inside the container for the background image (optional).
# BACKGROUND_DIR=/app/background

# Path inside the container for icon files (default.png and market.png).
# Mount ./icon here to replace icons without rebuilding the image.
# ICON_DIR=/app/icon
